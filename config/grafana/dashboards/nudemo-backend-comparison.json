          "format": "table",
          "rawSql": "SELECT s.backend, s.stage, s.pattern, s.status, s.sample_count, s.elapsed_sec, s.started_at, r.suite_name FROM telemetry_spans s JOIN telemetry_runs r ON s.run_id = r.run_id WHERE s.pattern NOT IN ('batch_ingest') AND s.status = 'ok' ORDER BY s.backend, s.stage, s.pattern, s.started_at DESC",
