  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 99,
      "options": {
        "content": "## nuDemo — Backend Comparison\nCompares **MinIO+PostgreSQL**, **Lance**, **Parquet**, and **WebDataset** across ingest throughput, sequential scan, random-access latency, curation query time, and disk footprint. Data is sourced directly from the telemetry database — all historical benchmark runs are included, with the best result per backend shown.\n\n> **Redis** is excluded from this comparison — it is the metadata index and embedding cache layer, not a blob storage backend. It stores ~2–5 KB/sample (tokens + embeddings) rather than ~2 MB/sample (JPEGs + LiDAR + radar).",
        "mode": "markdown"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "id": 100,
      "title": "Ingest Throughput  (samples / sec — higher is better)",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "nudemo-postgres" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "minio-postgres" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Redis" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Lance" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Parquet" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WebDataset" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "id": 1,
      "options": {
        "displayMode": "gradient", "minVizHeight": 10, "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "nudemo-postgres" },
          "format": "table",
          "rawSql": "SELECT backend, MAX((metrics->>'throughput_samples_per_sec')::float) AS \"Ingest (samp/s)\" FROM telemetry_spans WHERE pattern = 'batch_ingest' AND status = 'ok' AND backend != 'Redis' AND (metrics->>'throughput_samples_per_sec') IS NOT NULL GROUP BY backend ORDER BY 2 DESC",
          "refId": "A"
        }
      ],
      "title": "Best Ingest Throughput per Backend",
      "transformations": [
        { "id": "groupingToMatrix",
          "options": { "columnField": "backend", "rowField": "backend", "valueField": "Ingest (samp/s)" }
        }
      ],
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Sequential Scan vs Random Access vs Curation Query",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "nudemo-postgres" },
